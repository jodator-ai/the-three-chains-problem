#!/usr/bin/env bash
# configure-l2s - Configure and generate Docker Compose for N ZKsync OS L2 chains
#
# Usage:
#   ./configure-l2s --count=3
#   ./configure-l2s --count=4 --force-genesis
#   ./configure-l2s --count=2 --output=my-compose.yml
#
# After running, execute the printed docker compose command to start the chains.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Defaults
COUNT=""
OUTPUT="docker-compose.generated.yml"
FORCE_GENESIS=false
ZKSYNC_OS_VERSION="v30.2"
ZKSYNC_OS_SERVER_IMAGE="ghcr.io/matter-labs/zksync-os-server:latest"
L1_FOUNDRY_IMAGE="ghcr.io/foundry-rs/foundry:v1.3.4"

# Base chain ID: chain number N gets ID (BASE_CHAIN_ID + N)
BASE_CHAIN_ID=6564

# Chains 1 and 2 (IDs 6565, 6566) have pre-built configs in the upstream repo.
# Chains 3+ require genesis generation.
PREBUILT_MAX=2

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

log()   { echo -e "${GREEN}[configure-l2s]${NC} $*"; }
warn()  { echo -e "${YELLOW}[configure-l2s]${NC} $*"; }
error() { echo -e "${RED}[configure-l2s] ERROR:${NC} $*" >&2; exit 1; }
info()  { echo -e "${BLUE}[configure-l2s]${NC} $*"; }

usage() {
  cat <<EOF
${BOLD}configure-l2s${NC} - Generate Docker Compose for multiple ZKsync OS L2 chains

${BOLD}Usage:${NC}
  $0 --count=N [options]

${BOLD}Options:${NC}
  --count=N           Number of L2 chains to configure (minimum 1, maximum 8)
  --output=FILE       Output docker-compose file (default: docker-compose.generated.yml)
  --force-genesis     Force regeneration of genesis/chain configs even if they exist
  --version=VER       ZKsync OS protocol version (default: v30.2)
  --server-image=IMG  Docker image for zksync-os-server (default: latest)
  --help, -h          Show this help message

${BOLD}Examples:${NC}
  $0 --count=2          # Two L2 chains (uses pre-built configs, no genesis needed)
  $0 --count=3          # Three L2 chains (generates genesis for chain 3)
  $0 --count=4          # Four L2 chains (generates genesis for chains 3 and 4)
  $0 --count=3 --output=three-chains.yml

${BOLD}Chain IDs and Ports:${NC}
  Chain 1: ID=6565, RPC port (host)=5050
  Chain 2: ID=6566, RPC port (host)=5051
  Chain N: ID=$((BASE_CHAIN_ID))+N, RPC port (host)=$((5049))+N
  L1:      Chain ID=31337, port (host)=5010

EOF
  exit 0
}

# Parse arguments
for arg in "$@"; do
  case "$arg" in
    --count=*)        COUNT="${arg#*=}" ;;
    --output=*)       OUTPUT="${arg#*=}" ;;
    --force-genesis)  FORCE_GENESIS=true ;;
    --version=*)      ZKSYNC_OS_VERSION="${arg#*=}" ;;
    --server-image=*) ZKSYNC_OS_SERVER_IMAGE="${arg#*=}" ;;
    --help|-h)        usage ;;
    *) error "Unknown argument: $arg. Run $0 --help for usage." ;;
  esac
done

# Validate count
[[ -z "$COUNT" ]] && error "--count=N is required. Run $0 --help for usage."
[[ "$COUNT" =~ ^[0-9]+$ ]] || error "--count must be a positive integer"
[[ "$COUNT" -ge 1 ]] || error "--count must be at least 1"
[[ "$COUNT" -le 8 ]] || error "--count must be at most 8"

CONFIGS_DIR="$SCRIPT_DIR/configs/$ZKSYNC_OS_VERSION"
mkdir -p "$CONFIGS_DIR"

log "Configuring $COUNT L2 chain(s) for ZKsync OS $ZKSYNC_OS_VERSION"
echo ""

# ─────────────────────────────────────────────────────────────────────────────
# Step 1: Ensure chain configs exist
# ─────────────────────────────────────────────────────────────────────────────

# Determine which chains need genesis generation
chains_needing_genesis=()
for i in $(seq 1 "$COUNT"); do
  CHAIN_ID=$((BASE_CHAIN_ID + i))
  CONFIG_FILE="$CONFIGS_DIR/chain_${CHAIN_ID}.yaml"

  if [[ -f "$CONFIG_FILE" ]] && [[ "$FORCE_GENESIS" != "true" ]]; then
    log "Chain $CHAIN_ID: config already exists (use --force-genesis to regenerate)"
    continue
  fi

  if [[ "$i" -le "$PREBUILT_MAX" ]]; then
    info "Chain $CHAIN_ID: downloading pre-built config..."
    "$SCRIPT_DIR/scripts/download-upstream-configs.sh" \
      --chain-id="$CHAIN_ID" \
      --version="$ZKSYNC_OS_VERSION" \
      --output-dir="$CONFIGS_DIR"
  else
    chains_needing_genesis+=("$CHAIN_ID")
  fi
done

# Download genesis.json if missing
GENESIS_FILE="$CONFIGS_DIR/genesis.json"
if [[ ! -f "$GENESIS_FILE" ]] || [[ "$FORCE_GENESIS" == "true" ]]; then
  info "Downloading genesis.json..."
  "$SCRIPT_DIR/scripts/download-upstream-configs.sh" \
    --genesis-only \
    --version="$ZKSYNC_OS_VERSION" \
    --output-dir="$CONFIGS_DIR"
fi

# Download l1-state.json.gz if missing
L1_STATE_FILE="$CONFIGS_DIR/l1-state.json.gz"
if [[ ! -f "$L1_STATE_FILE" ]] || [[ "$FORCE_GENESIS" == "true" ]]; then
  info "Downloading L1 state..."
  "$SCRIPT_DIR/scripts/download-upstream-configs.sh" \
    --l1-state-only \
    --version="$ZKSYNC_OS_VERSION" \
    --output-dir="$CONFIGS_DIR"
fi

# If any chains need genesis generation, prompt and exit
if [[ ${#chains_needing_genesis[@]} -gt 0 ]]; then
  echo ""
  warn "Chains ${chains_needing_genesis[*]} need genesis generation."
  echo ""
  echo -e "These chains (3+) are not in the upstream pre-built configs and require"
  echo -e "L1 contract deployment. Run one of the following:"
  echo ""
  echo -e "  ${BOLD}Docker (recommended - no local tools needed, ~30min first run):${NC}"
  echo -e "  ./scripts/generate-genesis.sh --docker --count=$COUNT"
  echo ""
  echo -e "  ${BOLD}Local (requires Rust, yarn, foundry - see README):${NC}"
  echo -e "  ./scripts/generate-genesis.sh --count=$COUNT"
  echo ""
  echo "After genesis generation, re-run:"
  echo -e "  ${BOLD}$0 --count=$COUNT${NC}"
  echo ""
  exit 1
fi

# ─────────────────────────────────────────────────────────────────────────────
# Step 2: Generate docker-compose
# ─────────────────────────────────────────────────────────────────────────────

log "Generating $OUTPUT..."

"$SCRIPT_DIR/scripts/generate-compose.sh" \
  --count="$COUNT" \
  --version="$ZKSYNC_OS_VERSION" \
  --configs-dir="$CONFIGS_DIR" \
  --server-image="$ZKSYNC_OS_SERVER_IMAGE" \
  --l1-image="$L1_FOUNDRY_IMAGE" \
  --output="$OUTPUT"

# ─────────────────────────────────────────────────────────────────────────────
# Step 3: Print summary
# ─────────────────────────────────────────────────────────────────────────────

echo ""
echo -e "${GREEN}${BOLD}✓ Configuration complete!${NC}"
echo ""
echo -e "${BOLD}Chains configured:${NC}"
for i in $(seq 1 "$COUNT"); do
  CHAIN_ID=$((BASE_CHAIN_ID + i))
  EXT_PORT=$((5049 + i))
  echo "  Chain $i: ID=$CHAIN_ID  RPC → http://localhost:$EXT_PORT"
done
echo ""
echo -e "${BOLD}L1 (Anvil):${NC} http://localhost:5010  (chain ID: 31337)"
echo ""
echo -e "${BOLD}To start all chains:${NC}"
echo ""
echo -e "  ${BOLD}docker compose -f $OUTPUT up -d${NC}"
echo ""
echo -e "${BOLD}To view logs:${NC}"
echo ""
echo -e "  ${BOLD}docker compose -f $OUTPUT logs -f${NC}"
echo ""
echo -e "${BOLD}To stop:${NC}"
echo ""
echo -e "  ${BOLD}docker compose -f $OUTPUT down${NC}"
echo ""
